# Expo Frontend Configuration

# API Configuration
# Untuk Expo Go di HP asli, gunakan IP Wi-Fi laptop yang menjalankan backend.
# Jika menjalankan di emulator Android, ganti ke http://10.0.2.2:8000/api
# EXPO_PUBLIC_API_URL=http://192.168.14.58:8000/api #itats wifi KLS
EXPO_PUBLIC_API_URL=https://icy-eyes-cough.loca.lt #itats wifi KLS
EXPO_PUBLIC_APP_NAME=Sistem Absensi Digital SMKS Rajasa
EXPO_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
EXPO_PUBLIC_ENABLE_QR_SCANNER=true
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_APP_NAME=Sistem Absensi Digital SMKS Rajasa
EXPO_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
EXPO_PUBLIC_ENABLE_QR_SCANNER=true
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_GPS_VALIDATION=true
EXPO_PUBLIC_ENABLE_FACE_RECOGNITION=false

# Notification Configuration
EXPO_PUBLIC_NOTIFICATION_ENABLED=true

# Development
EXPO_PUBLIC_DEBUG_MODE=false

# API Key Security Signature Configuration
EXPO_PUBLIC_API_CLIENT_ID=smks-rajasa-app
EXPO_PUBLIC_API_CLIENT_SECRET=rajasa_secure_secret_key_2026
